#!/bin/zsh
# Reject AI attribution in commit messages. Enabled via core.hooksPath=.githooks
# (install.sh sets it; `git config core.hooksPath .githooks` if cloning fresh).
msg=$(grep -v '^#' "$1")

# Trailers and taglines that tools add to announce themselves.
if print -r -- "$msg" | grep -qiE \
  '(co-authored-by:.*(claude|codex|copilot|chatgpt|gpt|cursor|devin|aider|gemini|anthropic|openai))|(generated with .*(claude|codex|copilot|cursor|ai))|(🤖)|((authored|written|created) by (claude|an? ai|chatgpt|copilot))'
then
  cat >&2 <<'EOF'
commit-msg: AI attribution is not allowed in this repo.

Found one of: Co-Authored-By: <AI>, "Generated with ...", 🤖, "written by AI".
Write the message as the author of the change. See AGENTS.md.
EOF
  exit 1
fi
exit 0
